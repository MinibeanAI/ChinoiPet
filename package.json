{
  "name": "guofeng-stage-desktop-pet",
  "version": "0.1.0",
  "description": "A transparent guofeng desktop pet with reminders and calendar prompts.",
  "author": "douer",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite --host 127.0.0.1",
    "start": "electron .",
    "build": "tsc --noEmit && vite build",
    "check:assets": "node scripts/check-assets.mjs",
    "check:sequences": "node scripts/check-sequences.mjs",
    "check:lottie": "node scripts/check-lottie.mjs",
    "sequence:import-sheet": "node scripts/import-sequence-sheet.mjs",
    "sequence:import-keyposes": "node scripts/import-keypose-sheet.mjs",
    "sequence:import-video": "node scripts/import-sequence-video.mjs",
    "sequence:plan": "node scripts/plan-next-sequence.mjs",
    "sequence:brief": "node scripts/prepare-sequence-brief.mjs",
    "smoke:imports": "node scripts/smoke-imports.mjs",
    "preview:render": "node scripts/render-previews.mjs",
    "lottie:generate": "node scripts/generate-lottie-from-sequences.mjs",
    "video:beats": "node scripts/extract-video-beats.mjs",
    "icon:build": "node scripts/build-icon.mjs",
    "assets:clean-white-edges": "node scripts/clean-white-edges.mjs --write",
    "verify": "npm run check:assets && npm run check:sequences && npm run check:lottie && npm run preview:render && npm run build",
    "pack:mac": "node scripts/ensure-app-not-running.mjs && npm run build && electron-builder --publish never --mac dir",
    "dist:mac": "node scripts/ensure-app-not-running.mjs && npm run build && electron-builder --publish never --mac dmg",
    "dist:mac:no-notary": "node scripts/ensure-app-not-running.mjs && npm run build && PET_ADHOC_DEEP_SIGN=1 APPLE_NOTARYTOOL_PROFILE= CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never --mac dmg",
    "pack:win": "npm run build && electron-builder --publish never --win dir --x64",
    "dist:win": "npm run build && electron-builder --publish never --win nsis --x64",
    "notarize:artifact": "node scripts/notarize-artifact.mjs"
  },
  "dependencies": {
    "lottie-react": "^2.4.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^38.1.2",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "build": {
    "appId": "com.douer.guofeng-stage-desktop-pet",
    "productName": "国风桌宠",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/assets/character-front-alpha.png",
      "package.json"
    ],
    "asar": true,
    "afterPack": "scripts/after-pack-adhoc-sign.cjs",
    "afterAllArtifactBuild": "scripts/notarize-artifacts.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSCalendarsUsageDescription": "用于在日程开始前提醒你。",
        "NSAppleEventsUsageDescription": "用于读取系统 Calendar 中未来 24 小时的日程。"
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
